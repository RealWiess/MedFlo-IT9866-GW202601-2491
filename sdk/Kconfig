    bool "A and B Dual Boot System"
	  default n
	  help
        This enable to create A/B image and filesystem for dual boot.
    help_cht
        啟用 AB 系統雙開機。
    help_chs
        启用 AB 系统双开机。

config DYNAMIC_MOUNT_FS_ENABLE
    bool "Dynamic mount filesystem"
	  default n
	  depends on (A_B_DUAL_BOOT_ENABLE && !SUB_DATA_NONE)
	  help
        This enable to dynamically mount filesystem.
    help_cht
