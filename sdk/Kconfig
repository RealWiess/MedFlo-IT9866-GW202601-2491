    bool

config HAVE_AUDIO
    bool

config HAVE_VIDEO
    bool

config HAVE_TWO_WIEGAND
    bool

######################################################################
# Develop type definition
######################################################################
config CFG_DEVELOP
    string
    option env="CFG_DEVELOP"

if CFG_DEVELOP = "0"
config DEF_CFG_RELEASE
    def_bool y
endif

if CFG_DEVELOP = "1"
config DEF_CFG_DEVELOP
    def_bool y
endif

config CFG_VER_INTERNATIONAL
    string
    option env="CFG_VER_INTERNATIONAL"

if CFG_VER_INTERNATIONAL = "0"
config DEF_CFG_VER_CHINESE
    def_bool y
endif

if CFG_VER_INTERNATIONAL = "1"
config DEF_CFG_VER_INTERNATIONAL
    def_bool y
endif

######################################################################
# Configuration start
######################################################################
menu "Develop Environment"
#   hidden if DEF_CFG_DEVELOP

choice
    prompt "Develop Environment"
    default DEV_RELEASE if DEF_CFG_RELEASE
    default DEV_DEVELOP if DEF_CFG_DEVELOP
    help
        Choices the type of development environment. It will turn on all of the
        settings on the develop mode, else it only turns on the necessary settings on
        release mode.
    help_cht
        選擇開發環境。在開發模式之下，會顯示出所有的設定選項。在簡易模式之下，則只顯示常用的選項。
    help_chs
        选择开发环境。在开发模式之下，会显示出所有的设定选项。在简易模式之下，则只显示常用的选项。

config DEV_DEVELOP
    bool "Develop Mode"
    help
        Shows all of develop setting on develop mode
    help_cht
        開發模式 -- 顯示出所有選單
    help_chs
        开发模式 -- 显示出所有选单

config DEV_RELEASE
    bool "Release Mode"
    help
        Shows only required setting on release mode
    help_cht
        簡易模式 -- 只顯示出常用選單
    help_chs
        简易模式 -- 只显示出常用选单

endchoice

config BOOTLOADER_ENABLE
    bool "Enable bootloader or not"
    default n
    help
        Enable bootloader or not
    help_cht
        使用開機載入程式。
    help_chs
        使用启动加载程序。

endmenu

config CFG_PLATFORM
    string
    option env="CFG_PLATFORM"

config CMAKE_SOURCE_DIR
    string
    option env="CMAKE_SOURCE_DIR"

source "$CMAKE_SOURCE_DIR/$CFG_PLATFORM/Kconfig"

menu "System"

choice
    prompt "CPU type"
    default CPU_SM32 if DEF_CPU_SM32
    default CPU_FA626
    help
        Choice CPU type.
    help_cht
        主 CPU 選擇
    help_chs
        主 CPU 选择

config CPU_FA626
    bool "FA626"
    depends on CHIP_FAMILY_IT9860
    help
        FA626 (ARM9 CPU). For the IT90xx and IT98xx chips.
    help_cht
        使用 ARM 當主 CPU。IT90xx 與 IT98xx 系列使用 ARM 當主 CPU。
    help_chs
        使用 ARM 当主 CPU。IT90xx 与 IT98xx 系列使用 ARM 当主 CPU。

config CPU_SM32
    bool "SM32"
    help
        SM32 (ITE 32-bit RISC CPU). For the IT99xx chips.
    help_cht
        使用 ITE 專屬 RISC 當主 CPU。IT99xx 系列使用 ITE 專屬 RISC 當主 CPU。
    help_chs
        使用 ITE 专属 RISC 当主 CPU。IT99xx 系列使用 ITE 专属 RISC 当主 CPU。

endchoice

choice
    prompt "CPU SM32 endian"
    depends on CPU_SM32
    default CPU_BIG_ENDIAN
    help
        Endian type for SM32.
    help_cht
        設定 SM32 CPU 的 Endian 格式
    help_chs
        设定 SM32 CPU 的 Endian 格式

config CPU_BIG_ENDIAN
    bool "Big Endian"
    help
        Config SM32 as big endian.
    help_cht
        SM32 CPU 使用 Big Endian 格式
    help_chs
        SM32 CPU 使用 Big Endian 格式

config CPU_LITTLE_ENDIAN
    bool "Little Endian"
    depends on (CHIP_PKG_IT9852 || CHIP_PKG_IT9854 || CHIP_PKG_IT9856 || CHIP_FAMILY_IT9860)
    help
        Config SM32 as little endian.
    help_cht
        SM32 CPU 使用 Little Endian 格式
    help_chs
        SM32 CPU 使用 Little Endian 格式

endchoice

