config CHIP_FAMILY_IT9860
    bool
    default 'Y' if (DEF_CHIP_PKG_IT9860)

choice
    prompt "Chip Package"
    default CHIP_PKG_IT9862    if DEF_CHIP_PKG_IT9862
    default CHIP_PKG_IT9868    if DEF_CHIP_PKG_IT9868
    default CHIP_PKG_IT9868_AT if DEF_CHIP_PKG_IT9868_AT
    default CHIP_PKG_IT9869    if DEF_CHIP_PKG_IT9869
    default CHIP_PKG_IT9869_AT if DEF_CHIP_PKG_IT9869_AT
    default CHIP_PKG_IT9866    if (DEF_CHIP_PKG_IT9866 || DEF_CFG_VER_CHINESE)
	default CHIP_PKG_IT9866_AT if (DEF_CHIP_PKG_IT9866_AT || DEF_CFG_VER_CHINESE)
    default CHIP_PKG_IT9867    if (DEF_CHIP_PKG_IT9867 || DEF_CFG_VER_INTERNATIONAL)
	default CHIP_PKG_IT9867_AT if (DEF_CHIP_PKG_IT9867_AT || DEF_CFG_VER_INTERNATIONAL)

    help
        Chips package selected.
    help_cht
        晶片包裝
    help_chs
        芯片包装

