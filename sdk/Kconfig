config RAM_SIZE
    string "RAM Size"
    default "0x4000000"
    help
        Memory Size

        8M:     0x800000
        16M:    0x1000000
        32M:    0x2000000
        64M:    0x4000000
        128M:   0x8000000
    help_cht
        記憶體大小

        8M:     0x800000
        16M:    0x1000000
        32M:    0x2000000
        64M:    0x4000000
        128M:   0x8000000
    help_chs
        内存大小

        8M:     0x800000
        16M:    0x1000000
        32M:    0x2000000
        64M:    0x4000000
        128M:   0x8000000

config RAM_INIT_SCRIPT
    file "RAM initial script | ../../sdk/target/ram | *.scr"
    default "IT9860_396Mhz_DDR2_396Mhz.scr"
    help
        DRAM setting for booting. It puts in 'sdk\target\ram' directory.
    help_cht
        開機所需要的開機設定檔。放在 'sdk\target\ram' 路徑。
    help_chs
        开机所需要的开机配置文件。放在 'sdk\target\ram' 路径。

config MMAP_SIZE
    string "The size of memory mapping"
    default "0"
    help
        The size of memory mapping. RD internal use only.
    help_cht
        指定另一塊獨立空間的記憶體大小供供其它程式使用。當程式需要獨立切出記憶體使用時使用，例如 M2D。nedmalloc固定開銷64k的記憶體，因此可使用的記憶體為MMAP_SIZE - 64k。
    help_chs
        指定另一块独立空间的记忆体大小供其它程式使用。当程式需要独立切出记忆体使用时使用，例如 M2D。nedmalloc固定开销64k的记忆体，因此可使用的记忆体为MMAP_SIZE - 64k。

config WATCHDOG_ENABLE
    bool "Watch Dog enable"
    default n
    help
        Enable Watch Dog or not.
    help_cht
        啟用 Watch Dog 功能。如果此功能啟用，當系統一段時間沒有反應之後，會自動重啟。反應時間由 watchdog timeout 參數決定。
    help_chs
        启用 Watch Dog 功能。如果此功能启用，当系统一段时间没有反应之後，会自动重启。反应时间由 watchdog timeout 参数决定。

config WATCHDOG_TIMEOUT
    int "Watch Dog timeout"
    depends on WATCHDOG_ENABLE
    default 10000
    help
        Watch Dog timeout (ms).
    help_cht
        設定系統多少時間沒反應，會自動重啟。（單位：毫秒）
    help_chs
        设定系统多少时间没反应，会自动重启。（单位：毫秒）

config WATCHDOG_REFRESH_INTERVAL
    int "Watch Dog refresh interval"
    depends on WATCHDOG_ENABLE
    default 1000
    range 0 WATCHDOG_TIMEOUT
    help
        Watch Dog refresh interval (ms). Cannot exceed Watch Dog timeout.
    help_cht
        重置 Watch Dog 的時間間隔，必須小於重啟時間。（單位：毫秒）
    help_chs
        重置 Watch Dog 的时间间隔，必须小於重启时间。（单位：毫秒）

config WATCHDOG_INTR
    bool "Watch Dog interrupt enable"
    depends on WATCHDOG_ENABLE
    default n
    help
        Enable Watch Dog interrupt or not. The interrupt handler will be called when this feature is enabled.
    help_cht
        是否使用中斷，如果啟用這個功能，當 Watch dog 在 time out 之後，會呼叫一個特定程序來處理。
    help_chs
        是否使用中断，如果启用这个功能，当 Watch dog 在 time out 之后，会呼叫一个特定程序来处理。

config WATCHDOG_IDLETASK
    bool "Restart Watch Dog from idle task"
    depends on WATCHDOG_ENABLE
    default n
    help
        Restart Watch Dog from idle task or not.
    help_cht
        是否從Idle Task中重設 Watch dog。
    help_chs
        是否从Idle Task中重设 Watch dog。

config EXT_WATCHDOG_ENABLE
    bool "Use External Watch Dog Chip enable"
    default n
    help
        Enable External Watch Dog or not.
    help_cht
        啟用 外部 Watch Dog 功能。如果此功能啟用，當系統一段時間沒有反應之後，會自動重啟。反應時間由 watchdog timeout 參數決定。
    help_chs
        启用 外部 Watch Dog 功能。如果此功能启用，当系统一段时间没有反应之後，会自动重启。反应时间由 watchdog timeout 参数决定。
        
config PMIC_WD_ENABLE
    bool "PMIC Watch Dog enable"
    default n
    help
        Enable PMIC's Watch Dog or not
    help_cht
        啟用 PMIC Watch Dog 功能。如果此功能啟用，當系統一段時間沒有反應之後，會自動重啟。反應時間由 watchdog timeout 參數決定。
    help_chs
        启用 PMIC Watch Dog 功能。如果此功能启用，当系统一段时间没有反应之後，会自动重启。反应时间由 watchdog timeout 参数决定。
        
config PMIC_WATCHDOG_TIMEOUT
    int "PMIC Watch Dog timeout"
    depends on PMIC_WD_ENABLE
    default 5000
    help
        PMIC Watch Dog timeout (ms). PMIC support 1250 ms、2500 ms or 5000 ms.
    help_cht
        設定系統多少時間沒反應，會自動重啟，PMIC只支援1250、2500、5000。（單位：毫秒）
    help_chs
        设定系统多少时间没反应，会自动重启，PMIC只支援1250、2500、5000。（单位：毫秒）

config PMIC_WATCHDOG_REFRESH_INTERVAL
    int "PMIC Watch Dog refresh interval"
    depends on PMIC_WD_ENABLE
    default 1000
    range 0 PMIC_WATCHDOG_TIMEOUT
    help
        PMIC Watch Dog refresh interval (ms). Cannot exceed Watch Dog timeout.
    help_cht
        重置 PMIC Watch Dog 的時間間隔，必須小於重啟時間。（單位：毫秒）
    help_chs
        重置 PMIC Watch Dog 的时间间隔，必须小於重启时间。（单位：毫秒）
        
choice
    prompt "interface type"
    depends on PMIC_WD_ENABLE
    default PMIC_I2C0 if DEF_PMIC_I2C0
    default PMIC_I2C1 if DEF_PMIC_I2C1
