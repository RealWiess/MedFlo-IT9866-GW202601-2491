menu "Screen"
    depends on HAVE_LCD

config ENABLE_ROTATE
    bool "Rotate is enabled or not"
    default n
    help
        Rotate is enabled or not
    help_cht
        是否開啟旋轉功能 (90度/180度/270度)
    help_chs
        是否开启旋转功能 (90度/180度/270度)

config LCD_ENABLE
    bool "LCD enable"
    default n
    help
        Enable/Disable display output to LCD panel.
    help_cht
        使系統開啟/關閉 LCD 顯示的功能。
    help_chs
        使系统开启/关闭 LCD 显示的功能。

config LCD_WIDTH
    string "LCD width"
    depends on LCD_ENABLE
    default "1024"
    help
        LCD width in pixels.
    help_cht
        LCD 寬度。
    help_chs
        LCD 宽度。

config LCD_HEIGHT
    string "LCD height"
    depends on LCD_ENABLE
    default "600"
    help
        LCD height in pixels.
    help_cht
        LCD 高度。
    help_chs
        LCD 高度。

config LCD_PITCH
    string "LCD pitch"
    depends on LCD_ENABLE
    default "2048"
    help
        LCD pitch value.
    help_cht
        LCD pitch （通常值為 LCD 寬度 * LCD 每畫素佔的資料量）。
    help_chs
        LCD pitch （通常值为 LCD 宽度 * LCD 每画素占的数据量）。

config LCD_BPP
    string "LCD Bytes-Per-Pixel"
    depends on LCD_ENABLE
    default "2"
    help
        LCD Bytes-Per-Pixel value.
    help_cht
        LCD 每畫素佔的資料量 （RGB565 為兩個 bytes，RGB8888 為四個 bytes）
    help_chs
        LCD 每画素占的资料量 （RGB565 为两个 bytes，RGB8888 为四个 bytes）

config LCD_INIT_SCRIPT
    file "LCD initial script | ../../sdk/target/lcd | *.in *.txt"
    depends on LCD_ENABLE && !LCD_MULTIPLE
