config UPGRADE_CUSTOM_FLAGS
    int "Custom upgrade flags"
    depends on ((UPGRADE_BOOTLOADER || UPGRADE_IMAGE || UPGRADE_DATA) && (UPGRADE_BACKUP_RAW_DATA))
    default 0
    range 0 65535
    help
        Custom upgrade flags. (according to sdk/include/ite/ug.h definitions)
        UPGRADE_FW only: (0x1 << 0) = 1,
        UPGRADE_PARTITION_#2 only: (0x1 << 3) = 8,
        UPGRADE_FW, UPGRADE_PARTITION_#0 and UPGRADE_PARTITION_#3: (0x1 << 0) | (0x1 << 1) | (0x1 << 4) = 19
    help_cht
        自定義升級標誌。 (根據 sdk/include/ite/ug.h 的定義)
        UPGRADE_FW only: (0x1 << 0) = 1,
        UPGRADE_PARTITION_#2 only: (0x1 << 3) = 8,
        UPGRADE_FW, UPGRADE_PARTITION_#0 and UPGRADE_PARTITION_#3: (0x1 << 0) | (0x1 << 1) | (0x1 << 4) = 19
    help_chs
        自定义升级标志。 (根据 sdk/include/ite/ug.h 的定义)
        UPGRADE_FW only: (0x1 << 0) = 1,
        UPGRADE_PARTITION_#2 only: (0x1 << 3) = 8,
        UPGRADE_FW, UPGRADE_PARTITION_#0 and UPGRADE_PARTITION_#3: (0x1 << 0) | (0x1 << 1) | (0x1 << 4) = 19

endmenu


